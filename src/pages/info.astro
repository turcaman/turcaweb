---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ChangelogEntry from '../components/ChangelogEntry.astro';
import { releases } from '../data/releases';
---

<Layout title="Actualizaciones | Turcanime">
	<Header />
	<main class="max-w-3xl mx-auto px-5 pt-28 pb-24">
		<h1 class="text-3xl font-bold mb-2">Actualizaciones</h1>
		<p class="text-text-secondary text-sm mb-10">
			Este proyecto cambió de dueño recientemente. El registro comienza desde la versión 1.7.4 en adelante.
		</p>

		<div class="space-y-4">
			{releases.map((release, index) => <ChangelogEntry release={release} defaultOpen={index === 0} />)}
		</div>

		<div class="mt-8">
			<a href="/" class="text-primary hover:underline">← Volver al inicio</a>
		</div>
	</main>
	<Footer />
</Layout>
