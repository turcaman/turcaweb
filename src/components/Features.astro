---
import { BookOpen, Languages, Search, Shield } from '@lucide/astro';

const features = [
  { 
    title: 'Retoma al instante', 
    desc: 'No pierdas tiempo buscando. La app recuerda dónde te quedaste incluso tras cerrarla.',
    icon: BookOpen
  },
  { 
    title: 'Control total', 
    desc: 'Tú eliges el idioma de tu preferencia: Latino, Castellano o Subtitulado para cada episodio.',
    icon: Languages
  },
  { 
    title: 'Búsqueda instantánea', 
    desc: 'Resultados al momento. Encuentra tu anime favorito sin esperas ni publicidad.',
    icon: Search
  },
  { 
    title: 'Tu privacidad es ley', 
    desc: 'No guardamos tus datos. Todo se queda en tu dispositivo. Nada de cuentas, nada de rastreo.',
    icon: Shield
  },
];
---

<section class="px-5 pb-24">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 lg:grid-cols-4 gap-6">
    {features.map(({ title, desc, icon: Icon }) => (
      <div class="card-plain">
        <div class="text-primary mb-3">
          <Icon size={24} />
        </div>
        <h3 class="font-bold mb-2 text-white">{title}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">{desc}</p>
      </div>
    ))}
  </div>
</section>
