---
import { BookOpen, Languages, Search, Shield } from '@lucide/astro';

const features = [
  { 
    title: 'Sigue viendo', 
    desc: 'Retoma tus episodios justo donde los dejaste. La app guarda tu historial de visualización para que nunca pierdas tu progreso.',
    icon: BookOpen
  },
  { 
    title: 'Tú eliges el idioma', 
    desc: 'Acceso a múltiples servidores con opciones de audio Latino, Castellano o Subtitulado. Tú decides también qué servidor de video prefieres.',
    icon: Languages
  },
  { 
    title: 'Encuéntralo rápido', 
    desc: 'Búsqueda inteligente con sugerencias en tiempo real para que no pierdas ni un segundo buscando tu próxima serie.',
    icon: Search
  },
  { 
    title: '100% Privado', 
    desc: 'Tu historial y progreso se guardan solo en tu dispositivo. Sin cuentas, sin registros, sin rastreo.',
    icon: Shield
  },
];
---

<section class="px-5 pb-24">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 lg:grid-cols-4 gap-6">
    {features.map(({ title, desc, icon: Icon }) => (
      <div class="card-plain">
        <div class="text-primary mb-3">
          <Icon size={24} />
        </div>
        <h3 class="font-bold mb-2 text-white">{title}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">{desc}</p>
      </div>
    ))}
  </div>
</section>
