---
import { Play, Search, Shield } from '@lucide/astro';

const features = [
  {
    icon: Play,
    title: 'Streaming nativo',
    desc: 'Reproducción directa desde la fuente. Sin capas intermedias, sin demoras. Prev/next, auto-ocultación y modo paisaje.',
  },
  {
    icon: Search,
    title: 'Búsqueda inteligente',
    desc: 'Autocompletado, sugerencias en vivo e historial. Encontrá lo que buscas al instante.',
  },
  {
    icon: Shield,
    title: 'Sin publicidad',
    desc: 'Cero anuncios, cero rastreo, cero cuentas. La app no guarda nada tuyo fuera de tu dispositivo.',
  },
];
---

<section class="px-5 py-24 border-t border-border">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-3">No es una app más</h2>
    <p class="text-text-secondary text-center text-sm mb-14 max-w-lg mx-auto">
      Está hecha para los que saben lo que quieren y no toleran interrupciones.
    </p>

    <div class="grid md:grid-cols-3 gap-5">
      {features.map(({ icon: Icon, title, desc }) => (
        <div class="card-feature">
          <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center mb-5">
            <Icon size={20} class="text-primary" />
          </div>
          <h3 class="font-bold text-lg mb-2 text-white">{title}</h3>
          <p class="text-text-secondary text-sm leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
