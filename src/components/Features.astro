---
const coreFeatures = [
  {
    title: 'Historial local',
    desc: 'Tus episodios vistos y progreso se guardan exclusivamente en tu dispositivo.',
  },
  {
    title: 'Búsquedas persistentes',
    desc: 'Acceso rápido a tus términos de búsqueda recientes para retomar lo que buscabas.',
  },
  {
    title: 'Streaming nativo',
    desc: 'Reproducción directa del contenido sin abrir navegadores ni pestañas externas.',
  },
];
---

<section class="py-12 px-6 border-b border-border">
  <div class="max-w-4xl w-full">
    <div class="grid md:grid-cols-3 gap-8">
      {coreFeatures.map(({ title, desc }) => (
        <div>
          <h3 class="text-xs font-mono text-primary uppercase tracking-widest mb-2">{title}</h3>
          <p class="text-text-secondary text-sm leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
