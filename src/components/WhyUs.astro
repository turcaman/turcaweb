---
import { Check, X } from '@lucide/astro';
---
<section class="px-5 pb-24">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold mb-12 text-center">¿Por qué cambiarte a Turcanime?</h2>
    <div class="grid md:grid-cols-2 gap-8">
      <div class="p-8 rounded-2xl bg-surface border border-border">
        <h3 class="text-xl font-bold mb-6 text-text-secondary">Webs tradicionales</h3>
        <ul class="space-y-4 text-text-secondary">
          <li class="flex items-start gap-3">
            <X size={20} class="text-red-500 shrink-0" /> Publicidad intrusiva y molesta
          </li>
          <li class="flex items-start gap-3">
            <X size={20} class="text-red-500 shrink-0" /> Navegación caótica y difícil
          </li>
          <li class="flex items-start gap-3">
            <X size={20} class="text-red-500 shrink-0" /> El progreso se pierde al cerrar
          </li>
          <li class="flex items-start gap-3">
            <X size={20} class="text-red-500 shrink-0" /> Pocas opciones de idioma
          </li>
          <li class="flex items-start gap-3">
            <X size={20} class="text-red-500 shrink-0" /> Datos personales expuestos
          </li>
        </ul>
      </div>
      <div class="p-8 rounded-2xl bg-primary/10 border border-primary/20">
        <h3 class="text-xl font-bold mb-6 text-white">Turcanime</h3>
        <ul class="space-y-4 text-white">
          <li class="flex items-start gap-3">
            <Check size={20} class="text-primary shrink-0" /> 100% libre de anuncios
          </li>
          <li class="flex items-start gap-3">
            <Check size={20} class="text-primary shrink-0" /> Interfaz diseñada para fans
          </li>
          <li class="flex items-start gap-3">
            <Check size={20} class="text-primary shrink-0" /> Progreso guardado automáticamente
          </li>
          <li class="flex items-start gap-3">
            <Check size={20} class="text-primary shrink-0" /> SUB, Latino o Castellano
          </li>
          <li class="flex items-start gap-3">
            <Check size={20} class="text-primary shrink-0" />Máxima privacidad garantizada
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
