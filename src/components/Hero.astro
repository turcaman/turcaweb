---
import DownloadButton from './DownloadButton.astro';

const particles = Array.from({ length: 8 }, () => ({
  left: `${Math.random() * 100}%`,
  top: `${Math.random() * 100}%`,
  size: `${Math.random() * 2 + 1}px`,
  delay: `${Math.random() * 6}s`,
  duration: `${Math.random() * 6 + 5}s`,
}));
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-12">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(168,85,247,0.06)_0%,transparent_60%)] pointer-events-none" />

  {particles.map((p) => (
    <span
      class="absolute rounded-full bg-primary pointer-events-none"
      style={{
        left: p.left,
        top: p.top,
        width: p.size,
        height: p.size,
        animation: `particle-float ${p.duration} ease-out infinite`,
        animationDelay: p.delay,
      }}
    />
  ))}

  <div class="max-w-3xl mx-auto px-5 text-center relative z-10">
    <div class="inline-block relative mb-8">
      <div
        class="kanji-glitch text-[160px] md:text-[220px] leading-none font-bold select-none"
        data-text="解"
        style={{ color: '#fff', textShadow: '0 0 60px rgba(168,85,247,0.3)' }}
        aria-label="Kanji kai — desbloquear anime sin límites"
        role="img"
      >
        解
      </div>
    </div>

    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight mb-4 glow-text">
      Turcanime
    </h1>

    <p class="text-lg md:text-xl text-text-secondary mb-2 font-medium tracking-wide">
      Ver anime sin límites. <span class="text-primary/80">Técnicamente.</span>
    </p>

    <div class="h-10" />

    <div class="flex justify-center">
      <DownloadButton />
    </div>

    <div class="mt-5">
      <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-border text-xs font-mono text-text-secondary">
        <span class="w-1.5 h-1.5 rounded-full bg-primary animate-glow-pulse" />
        v1.10.1
      </span>
    </div>
  </div>
</section>
