---
import DownloadButton from './DownloadButton.astro';
const homeScreenshot = '/screenshots/home.jpeg';
---

<section class="bg-black min-h-screen flex items-center px-4 sm:px-6 py-8 sm:py-12">
	<div class="max-w-6xl mx-auto w-full">
		<div class="flex flex-col-reverse lg:flex-row items-center justify-center lg:justify-between gap-6 sm:gap-8">
			<div class="text-center lg:text-left">
				<h1 class="text-3xl sm:text-4xl lg:text-6xl font-extrabold text-white tracking-tight mb-2 sm:mb-3">Turcanime</h1>
				<p class="text-base sm:text-lg lg:text-xl text-gray-400 font-medium mb-1 sm:mb-2">Anime para Android. Streaming sin anuncios.</p>
				<p class="text-sm sm:text-base text-gray-500 mb-4 sm:mb-6">Sin anuncios. Sin registro. Solo anime.</p>
				<DownloadButton />
			</div>
			<div class="w-full max-w-[200px] sm:max-w-[240px] lg:max-w-[280px]">
				<img 
					src={homeScreenshot} 
					alt="Pantalla de inicio de Turcanime" 
					class="w-full h-auto aspect-[9/16] object-contain rounded-xl sm:rounded-2xl border-2 border-gray-800 shadow-2xl"
				/>
			</div>
		</div>
	</div>
</section>
