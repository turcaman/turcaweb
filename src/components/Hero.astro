---
import DownloadButton from './DownloadButton.astro';
---

<section class="min-h-[60vh] flex flex-col justify-center px-6 py-20 border-b border-border">
	<div class="max-w-4xl w-full">
		<div class="text-xs font-mono text-primary mb-4 tracking-widest uppercase">
			v1.7.5 stable
		</div>
		<h1 class="text-4xl md:text-6xl font-bold tracking-tighter mb-6 uppercase">
			Turcanime
		</h1>
		<p class="text-lg text-text-secondary mb-10 max-w-2xl leading-relaxed border-l-2 border-primary pl-6">
			Cliente de streaming de anime para Android. Código abierto. Sin rastreadores.
		</p>
		<div class="flex flex-wrap gap-3">
			<DownloadButton />
			<a 
				href="https://github.com/turcaman/turcanime" 
				target="_blank"
				class="btn-flat"
			>
				GITHUB
			</a>
		</div>
	</div>
</section>






