---
import type { Release } from '../data/releases';
interface Props {
  release: Release;
  defaultOpen?: boolean;
}
const { release, defaultOpen = false } = Astro.props;
---

<details class="group" open={defaultOpen}>
    <summary class="grid grid-cols-[auto_1fr_auto] items-center gap-3 cursor-pointer list-none py-4 px-5 rounded-lg bg-surface-elevated border border-border transition-colors hover:border-primary/30">
        <span class="text-primary font-mono text-sm font-bold shrink-0">{release.version}</span>
        <span class="text-white font-medium truncate">{release.title}</span>
        <span class="ml-auto text-text-secondary transition-transform group-open:rotate-180">▾</span>
    </summary>
    <div class="mt-2 p-5 rounded-lg bg-surface border border-border">
        <ul class="space-y-3 text-text-secondary">
            {release.changes.map((change) => (
                <li class="leading-relaxed pl-5 relative before:content-['▸'] before:absolute before:left-0 before:text-primary" set:html={change} />
            ))}
        </ul>
    </div>
</details>
